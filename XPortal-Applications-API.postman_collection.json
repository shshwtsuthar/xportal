          "name": "Combined Filters - Draft + Search",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/applications?status=Draft&search=Smith&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["applications"],
              "query": [
                {
                  "key": "status",
                  "value": "Draft"
                },
                {
                  "key": "search",
                  "value": "Smith"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Combined filters: Draft status + search for 'Smith' + pagination"
