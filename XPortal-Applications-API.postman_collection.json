  "item": [
    {
      "name": "1. List Applications",
      "item": [
        {
          "name": "List All Applications",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/applications",
              "host": ["{{baseUrl}}"],
              "path": ["applications"]
            },
            "description": "Get all applications with default pagination"
          },
          "response": []
        },
        {
          "name": "List Applications with Pagination",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/applications?page=1&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["applications"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            },
            "description": "Get applications with custom pagination"
          },
          "response": []
