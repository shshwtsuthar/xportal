                {
                  "key": "search",
                  "value": "John"
                }
              ]
            },
            "description": "Search applications by name containing 'John'"
          },
          "response": []
        },
        {
          "name": "Search by Email - example.com",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/applications?search=example.com",
              "host": ["{{baseUrl}}"],
              "path": ["applications"],
