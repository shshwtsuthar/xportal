          "response": []
        },
        {
          "name": "Search by Name - John",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/applications?search=John",
              "host": ["{{baseUrl}}"],
              "path": ["applications"],
